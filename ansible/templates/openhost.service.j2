[Unit]
Description=OpenHost Compute Space
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=host
WorkingDirectory=/home/host/openhost
Environment=PATH=/home/host/.pixi/bin:/home/host/openhost/.pixi/envs/default/bin:/usr/local/bin:/usr/bin:/bin
Environment=OPENHOST_ROUTER_CONFIG=/home/host/.openhost/local_compute_space/config.toml
# Enforce the host-runtime sentinel check on startup.  Only set on
# ansible-managed servers so `openhost up --dev` and the test suite
# don't need to create /etc/openhost/runtime.  See
# compute_space.core.runtime_sentinel for the contract.
Environment=OPENHOST_CHECK_RUNTIME_SENTINEL=1
ExecStart=/home/host/.pixi/bin/pixi run python -m compute_space
# Don't auto-restart on crash (can blow through certbot rate limits).
# RestartForceExitStatus=42 overrides Restart=no for exit code 42 only,
# which is used by the self-update flow to trigger a clean restart.
Restart=no
RestartForceExitStatus=42
SuccessExitStatus=42
RestartSec=3
# this will kill other processes in the group (eg caddy etc) after the main process exits
TimeoutStopSec=5

[Install]
WantedBy=multi-user.target
